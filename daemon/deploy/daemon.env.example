# /etc/gitvault-live/daemon.env 로 복사 후 값 채우기 — chmod 600 필수 (토큰 평문)
VAULT_PATH=<vault>
# REMOTE 는 vault 에 이미 origin 이 있으면 생략 가능 — 기기 자격증명 재사용
REMOTE=https://<user>:<token>@github.com/<owner>/<repo>.git
# 미지정 시 hostname 기반 자동 생성 후 .git/ogs-device-id 에 영속
DEVICE_ID=home-server
# git author.name 으로 쓸 표시 이름. 미지정 시 자동 감지:
#   git global user.name → homedir 이름(/Users/foodtech → foodtech) → deviceId 순으로 폴백 + '-bot' 접미어
#   (같은 기기의 plugin 커밋과 시각 구분: plugin=foodtech, daemon=foodtech-bot)
# DISPLAY_NAME=jaei-bot
DEBOUNCE_MS=3000
