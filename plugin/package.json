{
  "name": "obsidian-git-sync-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Obsidian 데스크톱 플러그인 — 백그라운드 git 자동 동기화 + 들어온 변경 인라인 표시 + 저장(squash-to-main).",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit",
    "test:hunks": "esbuild test/diffHunks.test.ts --bundle --platform=node --format=cjs --outfile=test/_bundle.cjs && node test/_bundle.cjs",
    "test:linediff": "esbuild test/lineDiff.test.ts --bundle --platform=node --format=cjs --outfile=test/_linediff.cjs && node test/_linediff.cjs",
    "test:git": "esbuild test/gitManager.test.ts --bundle --platform=node --format=cjs --outfile=test/_git.cjs && node test/_git.cjs",
    "test:relative": "esbuild test/relativeTime.test.ts --bundle --platform=node --format=cjs --outfile=test/_relative.cjs && node test/_relative.cjs",
    "test": "npm run test:hunks && npm run test:linediff && npm run test:git"
  },
  "dependencies": {
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@types/node": "^22.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.24.0",
    "obsidian": "^1.7.2",
    "typescript": "^5.6.0"
  }
}
